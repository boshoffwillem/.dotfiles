[user]
	name = Willem Boshoff
	email = boshoffwillem@protonmail.com
[core]
	autocrlf = input
	excludesfile = /Users/boshoffwillem/.gitignore_global
	pager = delta
    editor = nvim
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
[merge]
    conflictStyle = zdiff3
